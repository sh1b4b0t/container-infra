# LiteLLM Master Key - usado para autenticar requisições ao proxy
LITELLM_MASTER_KEY=sk-litellm-dev-key

# Salt Key - usado para criptografar API keys no banco
LITELLM_SALT_KEY=sk-litellm-salt-change-me

# Alibaba DashScope API Key
ALIBABA_API_KEY=your-alibaba-api-key-here

# Database URL (PostgreSQL via gateway)
DATABASE_URL=postgresql://postgres:postgres@192.168.64.1:5432/litellm

# Redis (via gateway)
REDIS_HOST=192.168.64.1
REDIS_PORT=6379